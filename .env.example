# === Обязательно в production ===
NODE_ENV=production
PORT=3001

# Публичный URL сайта (https, без слэша в конце) — для CORS и ссылок
SITE_URL=https://enterra.example

# За nginx / Cloudflare / reverse proxy
TRUST_PROXY=true

# Секрет JWT — сгенерируй длинную случайную строку
JWT_SECRET=change-me-to-a-long-random-secret

# Ключ для плагина EnterraAuth (= api-key в plugins/EnterraAuth/config.yml)
MINECRAFT_API_KEY=change-me-plugin-key

# Папка данных (БД + загрузки). На хосте укажи persistent volume
# DATA_DIR=/var/lib/enterra/data

# === Minecraft (статус онлайна на сайте) ===
MC_HOST=play.enterra.ru
MC_PORT=25565

# === Поддержка проекта (необязательно) ===
# SUPPORT_BOOSTY_URL=https://boosty.to/your-page
# SERVER_MONTHLY_COST=1500
