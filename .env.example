# === Обязательно в production ===
NODE_ENV=production
PORT=3001

# Публичный URL сайта (https, без слэша в конце) — для CORS и ссылок
SITE_URL=https://enterra.example

# За nginx / Cloudflare / reverse proxy
TRUST_PROXY=true

# Секрет JWT — сгенерируй длинную случайную строку
JWT_SECRET=change-me-to-a-long-random-secret

# Ключ для плагина EnterraAuth (= api-key в plugins/EnterraAuth/config.yml)
MINECRAFT_API_KEY=change-me-plugin-key

# Папка данных (БД + загрузки). На хосте укажи persistent volume
# DATA_DIR=/var/lib/enterra/data

# === Minecraft (статус онлайна на сайте) ===
MC_HOST=Enterra.minerent.io
MC_PORT=25565

# === EasyDonate (донаты и VIP) ===
# EASYDONATE_ENABLED=true
# EASYDONATE_SHOP_KEY=ключ из cp.easydonate.ru → настройки магазина
# EASYDONATE_SERVER_ID=ID сервера в магазине (раздел «Серверы»)
# EASYDONATE_SHOP_URL=https://ваш-магазин.easydonate.ru
# ID товаров VIP в магазине (1 / 3 / 6 месяцев):
# EASYDONATE_VIP_PRODUCT_1=12345
# EASYDONATE_VIP_PRODUCT_3=12346
# EASYDONATE_VIP_PRODUCT_6=12347
# Услуги (разбан / снять предупреждения):
# EASYDONATE_SERVICE_UNBAN=1098559
# EASYDONATE_SERVICE_CLEAR_WARNS=1098560
# EASYDONATE_PRODUCT_1098559_KIND=unban
# EASYDONATE_PRODUCT_1098560_KIND=clear_warns
# EASYDONATE_PRODUCT_1098559_CATEGORY=services
# EASYDONATE_PRODUCT_1098560_CATEGORY=services
# Категория товара на сайте (vip | privileges | items | bundles | services):
# EASYDONATE_PRODUCT_123456_CATEGORY=privileges
# Callback URL в панели EasyDonate:
# EASYDONATE_SUCCESS_URL=https://enterra.example/shop?payment=success

# OAuth: cp.donationalerts.com → приложения → ID приложения + API Key
# DONATION_ALERTS_CLIENT_ID=12345
# DONATION_ALERTS_CLIENT_SECRET=your_api_key_here
# Redirect URI в приложении DonationAlerts: https://enterra.tech/
# DONATION_ALERTS_REDIRECT_URI=https://enterra.tech/
# После первого OAuth токены хранятся в БД; можно также задать напрямую:
# DONATION_ALERTS_ACCESS_TOKEN=oauth_access_token
# Секретный токен из настроек аккаунта (виджеты / OBS):
# DONATION_ALERTS_WIDGET_TOKEN=your_widget_secret_token

# === ЮKassa (оплата VIP на сайте) ===
# shopId и секретный ключ — из личного кабинета ЮKassa → Интеграция → API ключи
# YOOKASSA_SHOP_ID=123456
# YOOKASSA_SECRET_KEY=live_xxxxxxxx
# Тестовый магазин: shopId и test_... ключ из кабинета ЮKassa
# URL возврата после оплаты (по умолчанию SITE_URL/support?payment=return)
# YOOKASSA_RETURN_URL=https://enterra.example/support?payment=return
# Webhook в кабинете ЮKassa: https://enterra.example/api/support/yookassa/webhook
# События: payment.succeeded, payment.canceled
# VIP_PURCHASE_ENABLED=false — отключить кнопку даже при настроенной ЮKassa

# === Реквизиты (переменные LEGAL_* для платёжных сервисов, API /api/legal) ===
# LEGAL_SELLER_NAME=Иванов Иван Иванович
# LEGAL_SELLER_STATUS=Самозанятый
# LEGAL_INN=123456789012
# LEGAL_OGRNIP=123456789012345
# LEGAL_EMAIL=enterrasupport@gmail.com
# LEGAL_PHONE=+7 900 000-00-00
# LEGAL_ADDRESS=г. Москва

# === Поддержка проекта (необязательно) ===
# SUPPORT_BOOSTY_URL=https://boosty.to/your-page
# SERVER_MONTHLY_COST=1500

# === Почта (только отправка кодов — не показывается на сайте) ===
# Gmail: пароль приложения (SMTP — часто блокируется на VDS, см. GMAIL_WEBAPP ниже)
SMTP_FROM=enterraverif@gmail.com
SMTP_USER=enterraverif@gmail.com
SMTP_PASS=your-gmail-app-password

# Обход блокировки SMTP на VDS — Google Apps Script (deploy/gmail-webapp/Code.gs)
GMAIL_WEBAPP_URL=https://script.google.com/macros/s/XXXX/exec
GMAIL_WEBAPP_SECRET=enterra-mail-secret-2026

# === Защита от спама и перегрузки (необязательно) ===
# BLOCKED_IPS=1.2.3.4,5.6.7.8
# SERVER_MAX_CONNECTIONS=400
# RATE_LIMIT_BURST=50
# RATE_LIMIT_GLOBAL=300
# RATE_LIMIT_API=100
# RATE_LIMIT_HEALTH=20
# RATE_LIMIT_PUBLIC=45
# RATE_LIMIT_LOGIN=10
# RATE_LIMIT_REGISTER=5
# RATE_LIMIT_EMAIL_CODE=8
# RATE_LIMIT_WRITE=18
# RATE_LIMIT_UPLOAD=10
# RATE_LIMIT_WEBHOOK=80
# RATE_LIMIT_MINECRAFT=500
# LOGIN_MAX_FAILURES=8
# LOGIN_BLOCK_MS=900000
# LOGIN_ACCOUNT_MAX_FAILURES=6
# LOGIN_ACCOUNT_BLOCK_MS=1800000
# RATE_LIMIT_ADMIN=60
# RATE_LIMIT_SENSITIVE=10
# RATE_LIMIT_AUTHENTICATED=80
# ABUSE_BAN_THRESHOLD=20
# ABUSE_WINDOW_MS=300000
# ABUSE_BAN_MS=1800000
# Для серьёзных DDoS: Cloudflare + deploy/nginx-http-limits.conf в nginx

# Альтернатива: Brevo HTTP API (https://brevo.com, бесплатно)
# BREVO_API_KEY=your-brevo-api-key
