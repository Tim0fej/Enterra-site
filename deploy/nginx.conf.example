# Пример nginx для production (замени enterra.example на свой домен)
#
# 1. Скопируй deploy/nginx-http-limits.conf в /etc/nginx/conf.d/enterra-limits.conf
# 2. В http { } добавь: include /etc/nginx/conf.d/enterra-limits.conf;

server {
    listen 80;
    server_name enterra.example;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name enterra.example;

    # ssl_certificate /etc/letsencrypt/live/enterra.example/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/enterra.example/privkey.pem;

    client_max_body_size 55M;
    limit_conn enterra_conn 50;

    location ~* ^/(\.env|\.git|wp-admin|wp-login|xmlrpc\.php|phpmyadmin) {
        return 444;
    }

    location = /api/health {
        limit_req zone=enterra_api burst=5 nodelay;
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /api/ {
        limit_req zone=enterra_api burst=30 nodelay;
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        limit_req zone=enterra_general burst=60 nodelay;
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
